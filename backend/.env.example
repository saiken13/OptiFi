# Database (asyncpg requires postgresql+asyncpg:// prefix)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Auth
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Groq (LLM) — https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Search API (https://serper.dev — free tier available)
SERPER_API_KEY=your-serper-api-key

# OneSignal Push Notifications (optional)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Auth cookie settings
# For separate frontend/backend domains in production:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Optional. Set only if you need to share cookies across subdomains.
COOKIE_DOMAIN=

# Email (Resend — free at resend.com, 100 emails/day free tier)
RESEND_API_KEY=re_your-resend-api-key
